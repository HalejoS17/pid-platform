import {
  BarChart3,
  Boxes,
  ChevronDown,
  Clock3,
  Filter,
  Gauge,
  ReceiptText,
  RotateCcw,
  TrendingDown,
  TrendingUp,
  UtensilsCrossed,
  WalletCards,
  AlertOctagon,
} from 'lucide-react';
import { useMemo,
  useState } from "react";
import type { ReactNode } from "react";
import { EChart } from "../components/EChart";
import {
  EmptyPanel,
  ErrorPanel,
  LoadingPanel,
  PageHeader,
  } from "../components/ui";
import { useMonthlyAnalytics } from "../hooks/use-monthly-imports";
import {
  formatCompactCurrency,
  formatCurrency,
  formatNumber,
  } from "../lib/format";
import type {
  MonthlyAnalyticsFilters,
} from '../types/monthly-imports';

import { ProfitabilityTable } from '../components/ProfitabilityTable';

const monthNames = [
  "Enero",
  "Febrero",
  "Marzo",
  "Abril",
  "Mayo",
  "Junio",
  "Julio",
  "Agosto",
  "Septiembre",
  "Octubre",
  "Noviembre",
  "Diciembre",
];

const selectClass =
  "w-full rounded-xl border border-white/20 bg-white px-3 py-2.5 text-sm text-slate-700 outline-none transition focus:border-blue-300 focus:ring-4 focus:ring-blue-400/20";

function initialPeriod() {
  const saved = localStorage.getItem("pid.analytics.period");

  if (saved) {
    try {
      const parsed = JSON.parse(saved) as {
        year?: number;
        month?: number;
      };

      if (parsed.year && parsed.month) {
        return {
          year: parsed.year,
          month: parsed.month,
        };
      }
    } catch {
      // Se utiliza el periodo inicial.
    }
  }

  return {
    year: 2024,
    month: 3,
  };
}

function MetricCard({
  label,
  value,
  detail,
  icon,
  tone,
}: {
  label: string;
  value: string;
  detail: string;
  icon: ReactNode;
  tone: "navy" | "blue" | "green" | "amber" | "red";
}) {
  const style = {
    navy: {
      border: "border-l-[#0C1D63]",
      icon: "bg-indigo-50 text-[#0C1D63]",
    },
    blue: {
      border: "border-l-[#2570B8]",
      icon: "bg-blue-50 text-[#2570B8]",
    },
    green: {
      border: "border-l-emerald-500",
      icon: "bg-emerald-50 text-emerald-600",
    },
    amber: {
      border: "border-l-amber-500",
      icon: "bg-amber-50 text-amber-600",
    },
    red: {
      border: "border-l-[#FF2402]",
      icon: "bg-red-50 text-[#FF2402]",
    },
  }[tone];

  return (
    <article
      className={`rounded-2xl border border-slate-200 border-l-4 bg-white p-5 shadow-sm ${style.border}`}
    >
      <div className="flex items-start justify-between gap-4">
        <div className="min-w-0">
          <p className="text-sm font-semibold text-slate-500">{label}</p>
          <p className="mt-2 text-2xl font-bold tracking-tight text-slate-950">
            {value}
          </p>
        </div>

        <div
          className={`flex size-11 shrink-0 items-center justify-center rounded-xl ${style.icon}`}
        >
          {icon}
        </div>
      </div>

      <p className="mt-3 text-xs leading-5 text-slate-500">{detail}</p>
    </article>
  );
}

function SectionTitle({
  eyebrow,
  title,
  description,
  icon,
}: {
  eyebrow: string;
  title: string;
  description: string;
  icon: ReactNode;
}) {
  return (
    <div className="mb-4 flex items-start gap-3">
      <div className="flex size-10 shrink-0 items-center justify-center rounded-xl bg-blue-50 text-[#2570B8]">
        {icon}
      </div>

      <div>
        <p className="text-xs font-bold uppercase tracking-[0.18em] text-[#2570B8]">
          {eyebrow}
        </p>
        <h2 className="mt-1 text-xl font-bold text-[#0C1D63]">{title}</h2>
        <p className="mt-1 text-sm leading-6 text-slate-500">{description}</p>
      </div>
    </div>
  );
}

function CorporateCard({
  title,
  subtitle,
  children,
}: {
  title: string;
  subtitle: string;
  children: ReactNode;
}) {
  return (
    <article className="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
      <div className="border-b border-slate-100 px-5 py-4">
        <h3 className="font-bold text-slate-900">{title}</h3>
        <p className="mt-1 text-sm text-slate-500">{subtitle}</p>
      </div>
      <div className="p-4">{children}</div>
    </article>
  );
}

export function DashboardPage() {
  const [period, setPeriod] = useState(initialPeriod);
  const [filters, setFilters] = useState<MonthlyAnalyticsFilters>({});
const query = useMonthlyAnalytics(period.year, period.month, filters);
  const data = query.data;

  const activeFilterCount = Object.values(filters).filter(Boolean).length;

  const updatePeriod = (next: { year: number; month: number }) => {
    setPeriod(next);
    localStorage.setItem("pid.analytics.period", JSON.stringify(next));
    setFilters({});
  };

  const salesGroupOption = useMemo<EChartsOption>(
    () => ({
      color: ["#2570B8", "#FF2402", "#0C1D63"],
      tooltip: {
        trigger: "axis",
      },
      legend: {
        top: 0,
        data: ["Ventas netas", "Costo estimado", "Margen %"],
      },
      grid: {
        left: 12,
        right: 24,
        top: 48,
        bottom: 72,
        containLabel: true,
      },
      xAxis: {
        type: "category",
        data: data?.salesByGroup.slice(0, 10).map((item) => item.name) ?? [],
        axisLabel: {
          rotate: 28,
          color: "#64748B",
        },
        axisTick: {
          show: false,
        },
      },
      yAxis: [
        {
          type: "value",
          axisLabel: {
            formatter: (value: string | number) =>
              formatCompactCurrency(Number(value)),
          },
          splitLine: {
            lineStyle: {
              color: "#EEF2F7",
            },
          },
        },
        {
          type: "value",
          min: 0,
          max: 1,
          axisLabel: {
            formatter: (value: string | number) =>
              `${Math.round(Number(value) * 100)}%`,
          },
        },
      ],
      series: [
        {
          name: "Ventas netas",
          type: "bar",
          data: data?.salesByGroup.slice(0, 10).map((item) => item.sales) ?? [],
          barMaxWidth: 34,
          itemStyle: {
            borderRadius: [7, 7, 0, 0],
          },
        },
        {
          name: "Costo estimado",
          type: "bar",
          data: data?.salesByGroup.slice(0, 10).map((item) => item.cost) ?? [],
          barMaxWidth: 34,
          itemStyle: {
            borderRadius: [7, 7, 0, 0],
          },
        },
        {
          name: "Margen %",
          type: "line",
          yAxisIndex: 1,
          smooth: true,
          symbolSize: 7,
          data:
            data?.salesByGroup.slice(0, 10).map((item) => item.marginPercent) ??
            [],
        },
      ],
    }),
    [data],
  );

  const dailySalesOption = useMemo<EChartsOption>(
    () => ({
      color: ["#2570B8"],
      tooltip: {
        trigger: "axis",
      },
      grid: {
        left: 12,
        right: 18,
        top: 22,
        bottom: 20,
        containLabel: true,
      },
      xAxis: {
        type: "category",
        data: data?.salesByDay.map((item) => item.date.slice(8, 10)) ?? [],
        axisLabel: {
          color: "#64748B",
        },
        axisTick: {
          show: false,
        },
      },
      yAxis: {
        type: "value",
        axisLabel: {
          formatter: (value: string | number) =>
            formatCompactCurrency(Number(value)),
        },
        splitLine: {
          lineStyle: {
            color: "#EEF2F7",
          },
        },
      },
      series: [
        {
          type: "line",
          name: "Ventas",
          data: data?.salesByDay.map((item) => item.sales) ?? [],
          smooth: true,
          symbol: "circle",
          symbolSize: 6,
          areaStyle: {
            opacity: 0.12,
          },
        },
      ],
    }),
    [data],
  );

  const agingOption = useMemo<EChartsOption>(
    () => ({
      color: ["#10B981", "#2570B8", "#F59E0B", "#FF2402"],
      tooltip: {
        trigger: "item",
      },
      legend: {
        bottom: 0,
        textStyle: {
          color: "#475569",
        },
      },
      series: [
        {
          type: "pie",
          radius: ["45%", "70%"],
          center: ["50%", "42%"],
          itemStyle: {
            borderColor: "#FFFFFF",
            borderWidth: 4,
            borderRadius: 8,
          },
          label: {
            formatter: "{b}\n{d}%",
            color: "#334155",
          },
          data: data?.inventoryAging ?? [],
        },
      ],
    }),
    [data],
  );

  const immobilizedOption = useMemo<EChartsOption>(
    () => ({
      color: ["#FF2402"],
      tooltip: {
        trigger: "axis",
      },
      grid: {
        left: 10,
        right: 18,
        top: 8,
        bottom: 10,
        containLabel: true,
      },
      xAxis: {
        type: "value",
        axisLabel: {
          formatter: (value: string | number) =>
            formatCompactCurrency(Number(value)),
        },
        splitLine: {
          lineStyle: {
            color: "#EEF2F7",
          },
        },
      },
      yAxis: {
        type: "category",
        data:
          data?.topImmobilized
            .slice(0, 10)
            .map((item) => item.itemName)
            .reverse() ?? [],
        axisLabel: {
          color: "#475569",
          width: 180,
          overflow: "truncate",
        },
        axisTick: {
          show: false,
        },
        axisLine: {
          show: false,
        },
      },
      series: [
        {
          type: "bar",
          data:
            data?.topImmobilized
              .slice(0, 10)
              .map((item) => item.value)
              .reverse() ?? [],
          barMaxWidth: 24,
          itemStyle: {
            borderRadius: [0, 7, 7, 0],
          },
        },
      ],
    }),
    [data],
  );

  const isNotFound =
    query.error instanceof AxiosError && query.error.response?.status === 404;

  if (query.isLoading) {
    return <LoadingPanel />;
  }

  return (
    <div className="space-y-7">
      <PageHeader
        title="Panel integral de inteligencia de datos"
        description="Indicadores financieros, comerciales y operativos consolidados para la toma de decisiones."
        onRefresh={() => {
          void query.refetch();
        }}
        refreshing={query.isFetching}
      />

      <details
        open
        className="group overflow-hidden rounded-2xl bg-[#0C1D63] shadow-lg"
      >
        <summary className="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-white marker:hidden">
          <div className="flex items-center gap-3">
            <div className="flex size-10 items-center justify-center rounded-xl bg-white/10">
