            </label>

            <label>
              <span className="mb-2 block text-sm font-semibold text-white">
                Mes
              </span>
              <select
                value={period.month}
                onChange={(event) =>
                  updatePeriod({
                    ...period,
                    month: Number(event.target.value),
                  })
                }
                className={selectClass}
              >
                {monthNames.map((name, index) => (
                  <option key={name} value={index + 1}>
                    {name}
                  </option>
                ))}
              </select>
            </label>

            <label>
              <span className="mb-2 block text-sm font-semibold text-white">
                Grupo 1
              </span>
              <select
                value={filters.group1 ?? ""}
                onChange={(event) => {
                  setFilters({
                    group1: event.target.value || undefined,
                  });
                }}
                className={selectClass}
              >
                <option value="">Todos los grupos</option>
                {(data?.filterOptions.groups1 ?? []).map((value) => (
                  <option key={value} value={value}>
                    {value}
                  </option>
                ))}
              </select>
            </label>

            <label>
              <span className="mb-2 block text-sm font-semibold text-white">
                Grupo 2
              </span>
              <select
                value={filters.group2 ?? ""}
                onChange={(event) => {
                  setFilters((current) => ({
                    group1: current.group1,
                    group2: event.target.value || undefined,
                  }));
                }}
                className={selectClass}
              >
                <option value="">Todos los subgrupos</option>
                {(data?.filterOptions.groups2 ?? []).map((value) => (
                  <option key={value} value={value}>
                    {value}
                  </option>
                ))}
              </select>
            </label>

            <label>
              <span className="mb-2 block text-sm font-semibold text-white">
                Plato o artículo
              </span>
              <select
                value={filters.article ?? ""}
                onChange={(event) => {
                  setFilters((current) => ({
                    ...current,
                    article: event.target.value || undefined,
                  }));
                }}
                className={selectClass}
              >
                <option value="">Todos los platos</option>
                {(data?.filterOptions.articles ?? []).map((value) => (
                  <option key={value} value={value}>
                    {value}
                  </option>
                ))}
              </select>
            </label>

            <label>
              <span className="mb-2 block text-sm font-semibold text-white">
                Insumo
              </span>
              <select
                value={filters.ingredient ?? ""}
                onChange={(event) => {
                  setFilters((current) => ({
                    ...current,
                    ingredient: event.target.value || undefined,
                  }));
                }}
                className={selectClass}
              >
                <option value="">Todos los insumos</option>
                {(data?.filterOptions.ingredients ?? []).map((value) => (
                  <option key={value} value={value}>
                    {value}
                  </option>
                ))}
              </select>
            </label>
          </div>

          <div className="mt-4 flex flex-col gap-3 border-t border-white/15 pt-4 sm:flex-row sm:items-center sm:justify-between">
            <div className="text-sm text-blue-100">
              Periodo:{" "}
              <strong className="text-white">
                {monthNames[period.month - 1]} {period.year}
              </strong>
              {data ? (
                <>
                  {" "}
                  · {formatNumber(data.filterSummary.salesLines)} líneas de
                  venta
                </>
              ) : null}
            </div>

            <button
              type="button"
              disabled={activeFilterCount === 0}
              onClick={() => {
                setFilters({});
              }}
              className="inline-flex items-center justify-center gap-2 rounded-xl border border-white/20 bg-white/10 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-white/20 disabled:cursor-not-allowed disabled:opacity-40"
            >
              <RotateCcw className="size-4" />
              Restablecer filtros
            </button>
          </div>
        </div>
      </details>

      {isNotFound ? (
        <EmptyPanel
          title="El periodo todavía no fue cargado"
          description="Abre Carga mensual, selecciona los cuatro Excel del mismo mes y procesa la importación."
        />
      ) : (
        <ErrorPanel errors={query.error ? [query.error] : []} />
      )}

      {data ? (
        <>
          <section>
            <SectionTitle
              eyebrow="Resumen gerencial"
              title="Indicadores clave"
              description="Principales métricas financieras y operativas del periodo seleccionado."
              icon={<BarChart3 className="size-5" />}
            />

            <div className="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
              <MetricCard
                label="Ventas netas"
                value={formatCurrency(data.kpis.netSales)}
                detail={`Facturación total: ${formatCurrency(
                  data.kpis.grossBilled,
                )}`}
                icon={<ReceiptText className="size-5" />}
                tone="navy"
              />
              <MetricCard
                label="Margen bruto estimado"
                value={`${(data.kpis.estimatedGrossMarginPercent * 100).toFixed(
                  1,
                )}%`}
                detail={`Cobertura de recetas: ${(
                  data.kpis.recipeCoveragePercent * 100
                ).toFixed(1)}%`}
                icon={<TrendingUp className="size-5" />}
                tone="green"
              />
              <MetricCard
                label="Costo estimado de ventas"
                value={formatCurrency(data.kpis.estimatedCostOfSales)}
                detail="Cantidad vendida multiplicada por el costo de receta homologado."
                icon={<UtensilsCrossed className="size-5" />}
                tone="blue"
              />
              <MetricCard
                label="Valor del inventario"
                value={formatCurrency(data.kpis.inventoryValue)}
                detail="Saldo positivo valorizado al costo promedio del cierre mensual."
                icon={<Banknote className="size-5" />}
                tone="navy"
              />
              <MetricCard
                label="Capital inmovilizado"
                value={formatCurrency(data.kpis.immobilizedCapital)}
                detail="Existencias sin salida o con rotación lenta superior a 60 días."
                icon={<AlertOctagon className="size-5" />}
                tone="red"
              />
              <MetricCard
                label="Rotación de inventario"
                value={`${data.kpis.rotation90Days.toFixed(2)}×`}
                detail="Salidas valorizadas frente al inventario promedio del alcance analizado."
                icon={<Gauge className="size-5" />}
                tone="blue"
              />
              <MetricCard
                label="Días de inventario"
                value={
                  data.kpis.inventoryDays === null
                    ? "Sin cálculo"
                    : `${formatNumber(data.kpis.inventoryDays)} días`
                }
                detail="Menos días suele representar una rotación más eficiente."
                icon={<Clock3 className="size-5" />}
                tone="amber"
              />
              <MetricCard
                label="Productos sin movimiento"
                value={formatNumber(data.kpis.noOutputProducts)}
                detail={`${data.kpis.slowRotationProducts} productos registran 60 días o más desde su última salida.`}
                icon={<WalletCards className="size-5" />}
                tone="red"
              />
            </div>
          </section>

          <section>
            <SectionTitle
              eyebrow="Desempeño comercial"
              title="Ventas y rentabilidad"
              description="Comportamiento de ingresos, costos y margen dentro del alcance seleccionado."
              icon={<TrendingUp className="size-5" />}
            />

            <div className="grid gap-6 xl:grid-cols-[1.35fr_0.9fr]">
              <CorporateCard
                title={`Ventas, costo y margen por ${data.breakdown.label.toLowerCase()}`}
                subtitle="Los diez elementos con mayor venta neta dentro del filtro."
              >
                <EChart option={salesGroupOption} height={390} />
              </CorporateCard>

              <CorporateCard
                title="Comportamiento diario de ventas"
                subtitle={`${monthNames[period.month - 1]} ${period.year}`}
              >
                <EChart option={dailySalesOption} height={390} />
              </CorporateCard>
            </div>
          </section>

          <section>
            <SectionTitle
              eyebrow="Análisis de rentabilidad"
              title="Rentabilidad por plato"
              description="Identificación de los platos con mayor y menor margen estimado."
              icon={<UtensilsCrossed className="size-5" />}
            />

            <div className="grid gap-6 xl:grid-cols-2">
              <CorporateCard
                title="Top 10 platos más rentables"
                subtitle="Ordenados por porcentaje de margen estimado."
              >
                <ProfitabilityTable
                  items={data.mostProfitableArticles}
                  mode="MOST"
                />
              </CorporateCard>

              <CorporateCard
                title="Top 10 platos menos rentables"
                subtitle="Ordenados desde el menor porcentaje de margen estimado."
              >
                <ProfitabilityTable
                  items={data.leastProfitableArticles}
                  mode="LEAST"
                />
              </CorporateCard>
            </div>
          </section>

          <section>
            <SectionTitle
              eyebrow="Gestión operativa"
              title="Inventario y rotación"
              description="Composición monetaria del inventario y capital con baja movilidad."
              icon={<Boxes className="size-5" />}
            />

            <div className="grid gap-6 xl:grid-cols-2">
              <CorporateCard
                title="Antigüedad monetaria del inventario"
                subtitle="Distribución del capital según los días desde la última salida."
              >
                <EChart option={agingOption} height={370} />
              </CorporateCard>

              <CorporateCard
                title="Productos con mayor capital detenido"
                subtitle="Priorización de existencias con baja movilidad."
              >
                {data.topImmobilized.length > 0 ? (
                  <EChart option={immobilizedOption} height={370} />
                ) : (
                  <EmptyPanel
                    title="Sin capital inmovilizado"
                    description="No se identificaron existencias detenidas para el filtro."
                  />
                )}
              </CorporateCard>
            </div>
          </section>

          <section>
            <SectionTitle
              eyebrow="Control de inventario"
              title="Detalle de existencias de baja rotación"
              description="Insumos que requieren seguimiento por su valor detenido y ausencia de movimiento."
              icon={<TrendingDown className="size-5" />}
            />

            <article className="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
              <div className="overflow-x-auto">
                <table className="w-full min-w-[980px] text-left text-sm">
                  <thead className="bg-[#0C1D63] text-xs uppercase tracking-wide text-white">
                    <tr>
                      <th className="px-5 py-4">Insumo</th>
                      <th className="px-5 py-4">Bodega</th>
                      <th className="px-5 py-4 text-right">Cantidad</th>
                      <th className="px-5 py-4 text-right">Costo promedio</th>
                      <th className="px-5 py-4 text-right">Valor detenido</th>
                      <th className="px-5 py-4 text-right">Días sin salida</th>
                    </tr>
                  </thead>

                  <tbody className="divide-y divide-slate-100">
                    {data.topImmobilized.map((item) => (
                      <tr
                        key={`${item.warehouseCode}:${item.itemName}`}
                        className="transition hover:bg-slate-50"
                      >
                        <td className="px-5 py-4 font-semibold text-slate-900">
                          {item.itemName}
                        </td>
                        <td className="px-5 py-4 text-slate-600">
                          {item.warehouseCode}
                        </td>
                        <td className="px-5 py-4 text-right">
                          {formatNumber(item.quantity)}
                        </td>
                        <td className="px-5 py-4 text-right">
                          {formatCurrency(item.averageCost)}
                        </td>
                        <td className="px-5 py-4 text-right font-bold text-[#FF2402]">
                          {formatCurrency(item.value)}
                        </td>
                        <td className="px-5 py-4 text-right">
                          <span className="inline-flex rounded-full bg-red-50 px-2.5 py-1 font-semibold text-red-700">
                            {item.daysWithoutOutput ?? "Sin salida"}
                          </span>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </article>
          </section>
        </>
      ) : null}
    </div>
  );
}
