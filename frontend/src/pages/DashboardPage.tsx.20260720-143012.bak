import type {
  EChartsOption,
} from 'echarts';
import {
  AlertOctagon,
  Banknote,
  Clock3,
  Filter,
  Gauge,
  ReceiptText,
  RotateCcw,
  TrendingUp,
  UtensilsCrossed,
  WalletCards,
} from 'lucide-react';
import { AxiosError } from 'axios';
import {
  useMemo,
  useState,
} from 'react';
import { EChart } from '../components/EChart';
import {
  ChartCard,
  EmptyPanel,
  ErrorPanel,
  KpiCard,
  LoadingPanel,
  PageHeader,
} from '../components/ui';
import { useMonthlyAnalytics } from '../hooks/use-monthly-imports';
import {
  formatCompactCurrency,
  formatCurrency,
  formatNumber,
} from '../lib/format';
import type {
  MonthlyAnalytics,
  MonthlyAnalyticsFilters,
} from '../types/monthly-imports';

const monthNames = [
  'Enero',
  'Febrero',
  'Marzo',
  'Abril',
  'Mayo',
  'Junio',
  'Julio',
  'Agosto',
  'Septiembre',
  'Octubre',
  'Noviembre',
  'Diciembre',
];

function initialPeriod() {
  const saved =
    localStorage.getItem(
      'pid.analytics.period',
    );

  if (saved) {
    try {
      const parsed =
        JSON.parse(saved) as {
          year?: number;
          month?: number;
        };

      if (
        parsed.year &&
        parsed.month
      ) {
        return {
          year: parsed.year,
          month: parsed.month,
        };
      }
    } catch {
      // Se usa el periodo inicial.
    }
  }

  return {
    year: 2024,
    month: 3,
  };
}

const selectClass =
  'w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm outline-none transition focus:border-[#2570B8] focus:ring-4 focus:ring-blue-100 disabled:cursor-not-allowed disabled:bg-slate-100';


function ProfitabilityTable({
  items,
  mode,
}: {
  items:
    MonthlyAnalytics['mostProfitableArticles'];
  mode: 'MOST' | 'LEAST';
}) {
  if (items.length === 0) {
    return (
      <div className="flex min-h-64 items-center justify-center p-6 text-center text-sm text-slate-500">
        No existen platos con receta homologada para el filtro seleccionado.
      </div>
    );
  }

  return (
    <div className="overflow-x-auto">
      <table className="w-full min-w-[720px] text-left text-sm">
        <thead className="bg-slate-50 text-xs uppercase tracking-wide text-slate-500">
          <tr>
            <th className="px-4 py-3">
              Posición
            </th>
            <th className="px-4 py-3">
              Plato
            </th>
            <th className="px-4 py-3 text-right">
              Ventas
            </th>
            <th className="px-4 py-3 text-right">
              Costo
            </th>
            <th className="px-4 py-3 text-right">
              Margen
            </th>
            <th className="px-4 py-3 text-right">
              Margen %
            </th>
          </tr>
        </thead>

        <tbody className="divide-y divide-slate-100">
          {items.map(
            (
              item,
              index,
            ) => (
              <tr
                key={item.name}
                className="hover:bg-slate-50"
              >
                <td className="px-4 py-3 font-semibold text-slate-500">
                  {index + 1}
                </td>

                <td className="px-4 py-3 font-semibold text-slate-900">
                  {item.name}
                </td>

                <td className="px-4 py-3 text-right">
                  {formatCurrency(
                    item.sales,
                  )}
                </td>

                <td className="px-4 py-3 text-right">
                  {formatCurrency(
                    item.cost,
                  )}
                </td>

                <td
                  className={
                    item.margin < 0
                      ? 'px-4 py-3 text-right font-semibold text-[#FF2402]'
                      : 'px-4 py-3 text-right font-semibold text-emerald-600'
                  }
                >
                  {formatCurrency(
                    item.margin,
                  )}
                </td>

                <td className="px-4 py-3 text-right">
                  <span
                    className={
                      mode === 'MOST'
                        ? 'inline-flex rounded-full bg-emerald-50 px-2.5 py-1 font-bold text-emerald-700'
                        : item.marginPercent < 0
                          ? 'inline-flex rounded-full bg-red-50 px-2.5 py-1 font-bold text-[#FF2402]'
                          : 'inline-flex rounded-full bg-amber-50 px-2.5 py-1 font-bold text-amber-700'
                    }
                  >
                    {(item.marginPercent * 100).toFixed(1) + '%'}
                  </span>
                </td>
              </tr>
            ),
          )}
        </tbody>
      </table>
    </div>
  );
}

export function DashboardPage() {
  const [
    period,
    setPeriod,
