                  filters.article
                }
              </span>
            ) : null}

            {filters.ingredient ? (
              <span className="rounded-full bg-white px-3 py-1 font-semibold">
                Insumo: {
                  filters.ingredient
                }
              </span>
            ) : null}

            <span className="ml-auto text-xs text-slate-600">
              {formatNumber(
                data.filterSummary
                  .salesLines,
              )}{' '}
              líneas de venta ·{' '}
              {formatNumber(
                data.filterSummary
                  .inventoryItems,
              )}{' '}
              insumos de inventario
            </span>
          </div>
        ) : null}
      </section>

      {isNotFound ? (
        <EmptyPanel
          title="El periodo todavía no fue cargado"
          description="Abre Carga mensual, selecciona los cuatro Excel del mismo mes y procesa la importación."
        />
      ) : (
