              .map(
                (item) =>
                  item.name,
              ) ?? [],

          axisLabel: {
            rotate: 28,
            color: '#64748B',
          },

          axisTick: {
            show: false,
          },
        },

        yAxis: [
          {
            type: 'value',

            axisLabel: {
              formatter: (
                value:
                  | string
                  | number,
              ) =>
                formatCompactCurrency(
                  Number(value),
                ),
            },

            splitLine: {
              lineStyle: {
                color: '#EEF2F7',
              },
            },
          },
          {
            type: 'value',
            min: 0,
            max: 1,

            axisLabel: {
              formatter: (
                value:
                  | string
                  | number,
              ) =>
                `${Math.round(
                  Number(value) *
                    100,
                )}%`,
