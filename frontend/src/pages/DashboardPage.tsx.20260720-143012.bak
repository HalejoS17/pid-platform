          data: [
            'Ventas netas',
            'Costo estimado',
            'Margen %',
          ],
        },

        grid: {
          left: 12,
          right: 24,
          top: 48,
          bottom: 70,
          containLabel: true,
        },

        xAxis: {
          type: 'category',

          data:
            data?.salesByGroup
