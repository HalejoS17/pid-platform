                    )} días`
              }
              detail="Menos días suele representar una rotación más eficiente."
              icon={
                <Clock3 className="size-5" />
              }
              tone="amber"
            />

            <KpiCard
              label="Productos sin salida"
              value={formatNumber(
                data.kpis
                  .noOutputProducts,
              )}
              detail={`${data.kpis.slowRotationProducts} productos registran 60 días o más desde su última salida.`}
              icon={
                <WalletCards className="size-5" />
              }
              tone="red"
            />
          </section>

          {data.filterSummary
            .salesLines === 0 ? (
            <EmptyPanel
              title="No existen ventas para el filtro"
              description="Prueba otra combinación de Grupo 1, Grupo 2, plato o insumo."
            />
          ) : null}

          <section className="grid gap-6 xl:grid-cols-[1.35fr_0.9fr]">
            <ChartCard
              title={`Ventas, costo y margen por ${data.breakdown.label.toLowerCase()}`}
              subtitle="Los diez elementos con mayor venta neta dentro del filtro."
            >
              <EChart
                option={
                  salesGroupOption
                }
                height={390}
              />
            </ChartCard>

            <ChartCard
              title="Ventas por día"
              subtitle={`${monthNames[period.month - 1]} ${period.year}`}
            >
              <EChart
                option={
                  dailySalesOption
                }
                height={390}
              />
            </ChartCard>
          </section>
          <section className="grid gap-6 xl:grid-cols-2">
            <ChartCard
              title="Top 10 platos más rentables"
              subtitle="Ordenados por porcentaje de margen estimado. Solo incluye platos con receta homologada y ventas netas positivas."
            >
              <ProfitabilityTable
                items={
                  data.mostProfitableArticles
                }
                mode="MOST"
              />
            </ChartCard>

            <ChartCard
              title="Top 10 platos menos rentables"
              subtitle="Ordenados desde el menor porcentaje de margen estimado. Los márgenes negativos requieren revisión prioritaria."
            >
              <ProfitabilityTable
                items={
                  data.leastProfitableArticles
                }
                mode="LEAST"
              />
            </ChartCard>
          </section>


          <section className="grid gap-6 xl:grid-cols-2">
            <ChartCard
              title="Ranking de meseros"
              subtitle="Ventas correspondientes al filtro seleccionado."
            >
              <EChart
                option={
                  waiterOption
                }
                height={370}
              />
            </ChartCard>

            <ChartCard
              title="Antigüedad monetaria del inventario"
              subtitle="Distribución monetaria del inventario asociado al filtro."
            >
              <EChart
                option={
                  agingOption
                }
                height={370}
              />
            </ChartCard>
          </section>

          <ChartCard
            title="Productos con mayor dinero detenido"
            subtitle="Prioridad de revisión dentro del filtro aplicado."
          >
            {data.topImmobilized
              .length > 0 ? (
              <EChart
                option={
                  immobilizedOption
                }
                height={420}
              />
            ) : (
              <EmptyPanel
                title="Sin capital inmovilizado"
                description="No se identificaron existencias detenidas para el filtro."
              />
            )}
          </ChartCard>

          <section className="surface-card overflow-hidden">
            <div className="border-b border-slate-200 p-5">
              <h2 className="font-semibold text-slate-900">
                Detalle de inventario detenido
              </h2>

              <p className="mt-1 text-sm text-slate-500">
                Cantidad, costo promedio, valor y última salida del alcance filtrado.
              </p>
            </div>

            <div className="table-scroll overflow-x-auto">
              <table className="w-full min-w-[950px] text-left text-sm">
                <thead className="bg-slate-50 text-xs uppercase tracking-wide text-slate-500">
                  <tr>
                    <th className="px-4 py-3">
                      Insumo
                    </th>

                    <th className="px-4 py-3">
                      Bodega
                    </th>

                    <th className="px-4 py-3 text-right">
                      Cantidad
                    </th>

                    <th className="px-4 py-3 text-right">
                      Costo promedio
                    </th>

                    <th className="px-4 py-3 text-right">
                      Valor detenido
                    </th>

                    <th className="px-4 py-3 text-right">
                      Días sin salida
                    </th>
                  </tr>
                </thead>

                <tbody className="divide-y divide-slate-100">
                  {data.topImmobilized.map(
                    (item) => (
                      <tr
                        key={`${item.warehouseCode}:${item.itemName}`}
                        className="hover:bg-red-50/30"
                      >
                        <td className="px-4 py-3 font-semibold text-slate-900">
                          {item.itemName}
                        </td>

                        <td className="px-4 py-3">
                          {item.warehouseCode}
                        </td>

                        <td className="px-4 py-3 text-right">
                          {formatNumber(
                            item.quantity,
                          )}
                        </td>

                        <td className="px-4 py-3 text-right">
                          {formatCurrency(
                            item.averageCost,
                          )}
                        </td>

                        <td className="px-4 py-3 text-right font-semibold text-[#FF2402]">
                          {formatCurrency(
                            item.value,
                          )}
                        </td>

                        <td className="px-4 py-3 text-right">
                          {item.daysWithoutOutput ??
                            'Sin salida'}
                        </td>
                      </tr>
                    ),
                  )}
                </tbody>
              </table>
            </div>
          </section>

          <div className="rounded-2xl border border-blue-100 bg-blue-50/80 p-4 text-sm leading-6 text-[#0C1D63]">
            <strong>
              Alcance del filtro:
            </strong>{' '}
            al seleccionar Grupo 1, Grupo 2 o plato, las ventas se filtran directamente y el inventario se limita a los ingredientes de sus recetas. Al seleccionar un insumo, las ventas representan los platos que usan ese insumo y el inventario representa únicamente ese insumo.
          </div>
        </>
      ) : null}
    </div>
  );
}