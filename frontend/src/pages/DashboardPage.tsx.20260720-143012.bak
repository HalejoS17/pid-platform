              'Costo estimado',
            type: 'bar',

            data:
              data?.salesByGroup
                .slice(0, 10)
                .map(
                  (item) =>
                    item.cost,
                ) ?? [],

            barMaxWidth: 36,

            itemStyle: {
              borderRadius: [
