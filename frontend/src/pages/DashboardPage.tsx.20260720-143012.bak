        </div>

        {activeFilterCount > 0 &&
        data ? (
          <div className="mt-4 flex flex-wrap items-center gap-2 rounded-xl bg-blue-50 p-3 text-sm text-[#0C1D63]">
            <strong>
              Filtro activo:
            </strong>

            {filters.group1 ? (
              <span className="rounded-full bg-white px-3 py-1 font-semibold">
                Grupo 1: {
                  filters.group1
                }
              </span>
            ) : null}

            {filters.group2 ? (
              <span className="rounded-full bg-white px-3 py-1 font-semibold">
                Grupo 2: {
                  filters.group2
