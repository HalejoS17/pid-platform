import {
  Route,
  Routes,
  } from 'react-router-dom';

import {
  AppShell,
  } from '../components/AppShell';

import {
  DashboardPage,
  } from '../pages/DashboardPage';

import {
  GoodsReceiptsPage,
} from '../pages/DataPages';

import {
  InventoryPage,
  MovementsPage,
} from '../pages/HistoricalDataPages';

import {
  NotFoundPage,
} from '../pages/NotFoundPage';

import { MonthlyImportsPage } from '../pages/MonthlyImportsPage';

import { WaitersPage } from '../pages/WaitersPage';
export function App() {
  return (
    <Routes>
      <Route
        element={<AppShell />}
      >
        <Route
          index
          element={
            <DashboardPage />
          }
        />

        <Route
          path="monthly-imports"
          element={
            <MonthlyImportsPage />
          }
        />

        <Route
          path="inventory"
          element={
            <InventoryPage />
          }
        />

        <Route
          path="movements"
          element={
            <MovementsPage />
          }
        />

        <Route
          path="goods-receipts"
          element={
            <GoodsReceiptsPage />
          }
        />

        <Route
          path="*"
          element={
            <NotFoundPage />
          }
        />
      </Route>
              <Route path="/waiters" element={<WaitersPage />} />
        </Routes>
  );
}